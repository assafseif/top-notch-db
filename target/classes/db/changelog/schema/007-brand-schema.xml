<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007-create-brand-table" author="copilot">
        <createTable tableName="brand" schemaName="dbo">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_brand" nullable="false"/>
            </column>
            <column name="name" type="NVARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_brand_name"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="008-add-product-brand-relation" author="copilot">
        <addColumn tableName="product" schemaName="dbo">
            <column name="brand_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="product"
                                 baseTableSchemaName="dbo"
                                 baseColumnNames="brand_id"
                                 referencedTableName="brand"
                                 referencedTableSchemaName="dbo"
                                 referencedColumnNames="id"
                                 constraintName="fk_product_brand_id"/>
    </changeSet>
</databaseChangeLog>